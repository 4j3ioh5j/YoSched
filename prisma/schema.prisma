generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  name           String
  passwordHash   String?
  groupId        String    // every user MUST belong to a group — authorization is group-based
  staffId     String?   @unique // links this login to a Staff record (self-service requests)
  isActive       Boolean   @default(true)
  totpSecret     String?
  totpEnabled    Boolean   @default(false)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  uiPreferences  Json      @default("{}") // per-login UI state (e.g. { usersTableSort: { column, dir } })
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Restrict)
  staff Staff? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  savedGraphViews SavedGraphView[]

  @@map("users")
}

model SavedGraphView {
  id        String   @id @default(cuid())
  name      String
  spec      Json // a GraphSpec
  ownerId   String? // User id of creator; null = department-owned (e.g. owner deleted)
  isShared  Boolean  @default(true) // default global; false = private to owner
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([isShared])
  @@map("saved_graph_views")
}

model Group {
  id                String   @id @default(cuid())
  name              String   @unique
  permissions       String[] @default([])
  level             Int      @default(0)
  isSystem          Boolean  @default(false)
  permissionsLocked Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  users             User[]

  @@map("groups")
}

model ShiftType {
  id              String   @id @default(cuid())
  name            String
  code            String   @unique
  defaultHours    Float    // hours this shift is worth on a WEEKDAY (the base value)
  defaultHoursWeekend Float @default(0) // hours on a Sat/Sun; 0 = does not accrue weekend hours (replaces the old countsOnWeekend flag)
  defaultHoursHoliday Float @default(0) // hours on a holiday; 0 = does not accrue holiday hours. Holiday takes precedence over weekend.
  countsTowardFte Boolean  @default(true)
  countsAsHolidayWork Boolean @default(true) // counts toward holiday-burden equity metric when worked on a holiday
  isLeave         Boolean  @default(false)
  isPaid          Boolean  @default(true)
  category        String   @default("work") // work, leave, imported, other
  color              String?
  printBackgroundColor String? // optional background tint for this shift's cells on the PRINTED schedule only (null = none); on-screen grid unaffected
  sortOrder          Int      @default(0)
  isOffShift         Boolean  @default(false)
  isFillShift        Boolean  @default(false)
  schedulePriority   Int?
  weekendPaired      Boolean  @default(false)
  holidayWeekendPaired Boolean @default(false) // when weekendPaired, also assign the same person to an adjacent holiday (Fri before / Mon after) for a 3-day holiday weekend
  ignoresWorkingDays Boolean  @default(false)
  noConsecutiveGroup String?
  maxPerDay          Int?
  autoSchedulable    Boolean  @default(false)
  hotkey             String?
  dedicatedColumn    Boolean  @default(false)
  boldOnSchedule     Boolean  @default(false) // render this shift's code in bold on the printed schedule
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments         Assignment[]
  desirabilityWeights DesirabilityWeight[]
  staffOverrides   StaffShiftOverride[]
  eligibleRoles       ShiftTypeRole[]
  standingCommitments StandingCommitment[]
  eligibleStaff            StaffEligibleShift[]
  defaultForEmploymentTypes    EmploymentTypeDefaultShift[]
  followRulesAsSource  ShiftFollowRule[] @relation("followRuleSource")
  followRulesAsAllowed ShiftFollowRule[] @relation("followRuleAllowed")
  requiredFollowerAsSource   RequiredFollower[] @relation("requiredFollowerSource")
  requiredFollowerAsFollower RequiredFollower[] @relation("requiredFollowerFollower")
  shiftEligibilityRules        ShiftEligibilityRule[]
  shiftMinimumTargets          ShiftMinimumTarget[]
  departmentTargets            DepartmentShiftTarget[]
  requestLeaveShifts           ScheduleRequest[] @relation("requestLeaveShift")

  @@map("shift_types")
}

model ShiftTypeRole {
  id          String @id @default(cuid())
  shiftTypeId String
  role        String

  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([shiftTypeId, role])
  @@map("shift_type_roles")
}

model EmploymentType {
  id                     String   @id @default(cuid())
  name                   String   @unique
  defaultIsAutoScheduled Boolean  @default(true)
  defaultFtePercentage   Float    @default(1.0)
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  staff                Staff[]
  defaultEligibleShifts    EmploymentTypeDefaultShift[]
  defaultAvailability      EmploymentTypeDefaultAvailability[]

  @@map("employment_types")
}

model Staff {
  id                    String   @id @default(cuid())
  name                  String
  initials              String   @unique
  employmentTypeId      String
  ftePercentage         Float?   @default(1.0)
  fteSplit              Json?    // e.g. {"OR": 0.8, "ICU": 0.2}
  feeBasisHoursPerShift Float?
  role                  String?
  specialQualifications String[] @default([])
  isTemporary           Boolean  @default(false)
  tempStartDate         DateTime?
  tempEndDate           DateTime?
  isActive              Boolean  @default(true)
  isAutoScheduled       Boolean  @default(true)
  offStrategyOrder      String[] @default([]) // per-staff default day-off fulfillment order; empty = inherit SchedulingPreferences.defaultOffStrategyOrder. Tokens: ORC_ADJACENT | ORL_PAIR | LEAVE:<shiftTypeId>.
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  employmentType    EmploymentType         @relation(fields: [employmentTypeId], references: [id])
  assignments       Assignment[]
  shiftOverrides    StaffShiftOverride[]
  standingCommitments StandingCommitment[]
  dayPreferences    StaffDayPreference[]
  eligibleShifts          StaffEligibleShift[]
  availabilityRules       AvailabilityRule[]     @relation("staffRules")
  conditionedRules        AvailabilityRule[]     @relation("conditionStaff")
  shiftEligibilityRules   ShiftEligibilityRule[]
  shiftMinimumTargets     ShiftMinimumTarget[]
  scheduleRequests        ScheduleRequest[]
  loginUser               User?

  @@map("staff")
}

model StaffShiftOverride {
  id          String @id @default(cuid())
  staffId  String
  shiftTypeId String
  durationHrs Float // legacy base / fallback when a day-type value is unset
  // Day-type-aware hours. Null = fall back to durationHrs (legacy single value
  // is treated as both weekday and weekend until a split is set).
  durationHrsWeekday Float?
  durationHrsWeekend Float?
  // Null = fall back to the weekend resolution (legacy rows have no holiday value;
  // holidays mirrored the weekend hours until an explicit per-staff holiday split).
  durationHrsHoliday Float?

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([staffId, shiftTypeId])
  @@map("staff_shift_overrides")
}

model StaffDayPreference {
  id         String @id @default(cuid())
  staffId String
  dayOfWeek  Int    // 0=Sun..6=Sat
  preference String // e.g. "ORC" — preferred shift on this day

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@map("staff_day_preferences")
}

model StandingCommitment {
  id          String @id @default(cuid())
  staffId  String
  shiftTypeId String
  notes       String?
  // Unified WHEN model (recurrence.ts) — the sole recurrence representation
  // since slice 7 dropped the legacy dayOfWeek + frequency columns.
  whenKind        String?
  whenDays        Int[]   @default([])
  whenPpWeek      Int?
  whenOrds        Int[]   @default([])
  whenCycleUnit   String?
  whenCycleN      Int?
  whenCycleOffset Int?

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@map("standing_commitments")
}

model DesirabilityWeight {
  id          String @id @default(cuid())
  shiftTypeId String
  dayOfWeek   Int    // 0=Sun..6=Sat
  weight      Int    // -5 (terrible) to +5 (great)
  reason      String?

  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([shiftTypeId, dayOfWeek])
  @@map("desirability_weights")
}

model StaffingMinimum {
  id           String @id @default(cuid())
  role         String
  dayType      String // weekday, weekend, holiday
  minimumCount Int

  @@unique([role, dayType])
  @@map("staffing_minimums")
}

model ShiftCountRule {
  id         String @id @default(cuid())
  shiftCode  String
  dayType    String // weekday, weekend, holiday
  exactCount Int

  @@unique([shiftCode, dayType])
  @@map("shift_count_rules")
}

model StaffingRequirement {
  id        String @id @default(cuid())
  shiftCode String
  dayKey    String // "0"=Sun, "1"=Mon, ..., "6"=Sat, "holiday"
  minCount  Int    @default(0)

  @@unique([shiftCode, dayKey])
  @@map("staffing_requirements")
}

model PayPeriod {
  id          String   @id @default(cuid())
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  targetHours Float

  @@map("pay_periods")
}

model FteTarget {
  id            String @id @default(cuid())
  ftePercentage Float  @unique
  targetHours   Float

  @@map("fte_targets")
}

model Holiday {
  id   String   @id @default(cuid())
  date DateTime @unique @db.Date
  name String

  @@map("holidays")
}

// Singleton SMTP config for outbound mail (id always "default"). The password is
// write-only over the API — never serialized back to a client.
model EmailSettings {
  id          String   @id @default("default")
  enabled     Boolean  @default(false)
  host        String?
  port        Int      @default(587)
  secure      Boolean  @default(false) // true = implicit TLS (465); false = STARTTLS (587)
  username    String?
  password    String? // SMTP password — write-only via API
  fromAddress String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_settings")
}

model SchedulingPreferences {
  id                    String  @id @default(cuid())
  prefer3DayWeekends    Boolean @default(true)
  prefer4DayWeekends    Boolean @default(true)
  preferSequentialOff   Boolean @default(true)
  sequentialOffWeight   Float   @default(2)
  threeDayWeekendWeight   Float   @default(5)
  fourDayWeekendWeight  Float   @default(8)
  equityThresholdLow    Float   @default(0.25)
  equityThresholdMed    Float   @default(0.75)
  equityThresholdHigh   Float   @default(1.5)
  deviceTrustDays       Int     @default(30)
  dateFormat            String  @default("MMMM D, YYYY")
  maxLeavePerDay        Int     @default(0) // soft cap on staff off per day; 0 = no cap
  pendingRequestMode    String  @default("full") // auto-scheduler handling of PENDING (unapproved) requests: "off" | "soft" | "full"
  requestConflictPolicy String  @default("reconcile") // forced-request contention: "reconcile" (tentative + first-come) | "honor-always"
  defaultOffStrategyOrder String[] @default(["ORC_ADJACENT", "ORL_PAIR"]) // dept-wide default day-off fulfillment order; admin appends LEAVE:<shiftTypeId> tokens. Seeds the My Requests widget + per-staff override.
  defaultLiveScope        String   @default("day") // default re-solve scope for auto-generate edits: "limited" | "day" | "pp" | "range" (#248). Seeds the grid's scope selector.

  @@map("scheduling_preferences")
}

// Last-seen heartbeat per login, used ONLY to show a passive "other editors are
// active" banner on the schedule page. One row per user (keyed by userId), upserted
// on each heartbeat. NOT a session store and NOT a page tracker — it records that a
// login is currently active *somewhere*, nothing about which page. "Active" is decided
// at read time by a freshness TTL (see src/lib/presence.ts), so a closed tab silently
// ages out. Plain column, no FK back-reference: presence is disposable, never blocks a
// user delete (a stale row is harmless and is overwritten on that user's next login).
model UserActivity {
  userId   String   @id
  lastSeen DateTime @default(now())

  @@index([lastSeen])
  @@map("user_activity")
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("login_logs")
}

model EquityFactor {
  id         String  @id @default(cuid())
  factorType String  // "desirability", "holiday", "shift"
  shiftCode  String? // only for factorType="shift"
  weight     Float   @default(1.0)
  enabled    Boolean @default(true)
  sortOrder  Int     @default(0)

  @@unique([factorType, shiftCode])
  @@map("equity_factors")
}

// Admin-editable, ordered priority of the NEGOTIABLE auto-generation factors — the
// order in which the objective grades a finished schedule (lexicographic `rank[]`).
// Slice 1 of #252: persist + reorder the OBJECTIVE only. Seeded to today's four
// aggregate tiers in their current order so default output is unchanged (the engine
// falls back to the hardcoded order when config is absent/invalid). Structural
// constraints (double-booking, eligibility, locked/manual cells, approved-hard
// requests) are NOT rows here — they're pinned above every factor.
model AutoGenFactor {
  id        String  @id @default(cuid())
  key       String  @unique // stable factor id, e.g. "coverageAndHardLimits" | "ppHours" | "requests" | "fairness"
  label     String
  sortOrder Int     @default(0) // lexicographic precedence; 0 = highest priority
  enabled   Boolean @default(true)
  // "soft" | "hardOverridable" — validated in app code. Inert in Slice 1; consumed in
  // Slice 2 when hours splits into over (soft) / under (hardOverridable). (`weight` was
  // intentionally omitted until the Slice 3 tier/group model needs it — Codex #1752.)
  hardness  String  @default("soft")

  @@map("autogen_factors")
}

model Assignment {
  id          String   @id @default(cuid())
  staffId  String
  date        DateTime @db.Date
  shiftTypeId String
  isLocked    Boolean  @default(false)
  source      String   @default("manual") // manual, auto, imported, request (placed by an approved schedule request)
  // For source="auto" rows: the "YYYY-MM" calendar month the Auto-schedule run
  // targeted (the run's view, even when its window expands to pay-period edges
  // that spill into adjacent months). Lets "Clear Auto" of a month remove that
  // month's auto cells AND its overflow into neighbouring months, by origin
  // rather than by date — and leave another month's run untouched. Null for
  // manual/imported rows and for auto rows written before this column existed
  // (those fall back to the month-range clear).
  autoMonth   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Acting user's id on the last write. Plain nullable column (NOT a FK) so
  // deleting a user never blocks assignment history. Resolved to a NAME (never
  // the id/email) for schedule:edit viewers — surfaced in the cell tooltip
  // ("changed by X") and in conflict payloads; plain viewers never receive it.
  updatedBy   String?
  // The ShiftType.id the Auto-schedule run originally placed here, captured ONLY
  // when a manual edit overwrites a source="auto" cell with a different value.
  // Lets the cell tooltip render "Auto → Manual (was ORC)". Plain nullable column
  // (NOT a FK), same rationale as updatedBy: deleting a ShiftType must never
  // cascade-delete assignment history. Null for cells that were never auto, for
  // unedited auto cells, and for auto rows a fresh run (re)writes (those ARE the
  // auto value). Resolved to a code client-side via the grid's shiftType map.
  autoShiftTypeId String?

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([staffId, date])
  @@index([autoMonth])
  @@map("assignments")
}

model StaffEligibleShift {
  id          String @id @default(cuid())
  staffId  String
  shiftTypeId String

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([staffId, shiftTypeId])
  @@map("staff_eligible_shifts")
}

model EmploymentTypeDefaultShift {
  id               String @id @default(cuid())
  employmentTypeId String
  shiftTypeId      String

  employmentType EmploymentType @relation(fields: [employmentTypeId], references: [id], onDelete: Cascade)
  shiftType      ShiftType      @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([employmentTypeId, shiftTypeId])
  @@map("employment_type_default_shifts")
}

model AvailabilityRule {
  id                  String  @id @default(cuid())
  staffId          String
  type                String  @default("available") // "available" or "unavailable"
  strength            String  @default("rule") // "rule" or "preference"
  conditionStaffId String?
  conditionType       String? // "working" or "not_working"
  // Unified WHEN model (recurrence.ts) — sole recurrence representation since
  // slice 7 dropped legacy dayOfWeek/pattern/cycleLength/cycleOffset.
  whenKind            String?
  whenDays            Int[]   @default([])
  whenPpWeek          Int?
  whenOrds            Int[]   @default([])
  whenCycleUnit       String?
  whenCycleN          Int?
  whenCycleOffset     Int?

  staff          Staff  @relation("staffRules", fields: [staffId], references: [id], onDelete: Cascade)
  conditionStaff Staff? @relation("conditionStaff", fields: [conditionStaffId], references: [id], onDelete: SetNull)

  @@map("availability_rules")
}

model EmploymentTypeDefaultAvailability {
  id               String @id @default(cuid())
  employmentTypeId String
  type             String @default("available")
  strength         String @default("rule")
  // Unified WHEN model (recurrence.ts) — sole recurrence representation since
  // slice 7 dropped the legacy dayOfWeek/pattern columns.
  whenKind        String?
  whenDays        Int[]   @default([])
  whenPpWeek      Int?
  whenOrds        Int[]   @default([])
  whenCycleUnit   String?
  whenCycleN      Int?
  whenCycleOffset Int?

  employmentType EmploymentType @relation(fields: [employmentTypeId], references: [id], onDelete: Cascade)

  @@map("employment_type_default_availability")
}

model ShiftFollowRule {
  id             String   @id @default(cuid())
  sourceShiftId  String
  allowedShiftId String?
  allowOffShifts Boolean  @default(false)
  mode           String   @default("allow")
  createdAt      DateTime @default(now())

  sourceShift  ShiftType  @relation("followRuleSource", fields: [sourceShiftId], references: [id], onDelete: Cascade)
  allowedShift ShiftType? @relation("followRuleAllowed", fields: [allowedShiftId], references: [id], onDelete: Cascade)

  @@unique([sourceShiftId, allowedShiftId])
  @@map("shift_follow_rules")
}

// A REQUIRED follower: after a source shift the engine auto-places `followerShift`
// on the next eligible day. Complements ShiftFollowRule (which only says what MAY
// follow). `scope` = "each_day" (after every occurrence, e.g. ORC→X recovery) or
// "each_run" (once after a consecutive run, e.g. a CALL weekend → one ADM).
// `countsTowardTargets` decides whether the placed follower satisfies staffing
// requirements / min-max targets for its own shift (its worked hours always count
// toward FTE regardless). Fully editable in settings — no shift codes live in code.
model RequiredFollower {
  id                  String   @id @default(cuid())
  sourceShiftId       String
  followerShiftId     String
  scope               String   @default("each_day") // "each_day" | "each_run"
  countsTowardTargets Boolean  @default(false)
  createdAt           DateTime @default(now())

  sourceShift   ShiftType @relation("requiredFollowerSource", fields: [sourceShiftId], references: [id], onDelete: Cascade)
  followerShift ShiftType @relation("requiredFollowerFollower", fields: [followerShiftId], references: [id], onDelete: Cascade)

  @@unique([sourceShiftId])
  @@map("required_followers")
}

model ShiftEligibilityRule {
  id          String @id @default(cuid())
  staffId  String
  shiftTypeId String
  type        String @default("eligible")
  strength    String @default("rule")
  // Unified WHEN model (recurrence.ts) — sole recurrence representation since
  // slice 7 dropped legacy dayOfWeek/pattern/cycleLength/cycleOffset.
  whenKind        String?
  whenDays        Int[]   @default([])
  whenPpWeek      Int?
  whenOrds        Int[]   @default([])
  whenCycleUnit   String?
  whenCycleN      Int?
  whenCycleOffset Int?

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@index([staffId, shiftTypeId])
  @@map("shift_eligibility_rules")
}

model ShiftMinimumTarget {
  id          String @id @default(cuid())
  staffId  String
  shiftTypeId String
  minCount    Int
  maxCount    Int?
  window      String
  windowDays  Int?
  windowCount Int    @default(1) // multiplier: "per N windows" (e.g. 1 per 3 pay periods). Ignored for window="days".

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([staffId, shiftTypeId, window, windowCount], map: "shift_min_targets_staff_shift_window_count_key")
  @@map("shift_minimum_targets")
}

// Department-wide shift count targets ("Pay-period preferences"). Same min/max +
// window shape as ShiftMinimumTarget, but NOT keyed to a staff member: each row
// is a default that applies to everyone, with counts expressed PER 1.0 FTE
// (perFte) and scaled to each staff's ftePercentage at schedule time. A per-staff
// ShiftMinimumTarget for the same (shiftType, window, windowCount) OVERRIDES the
// department default. `strength` lets a row be a soft preference (bias only) or a
// hard rule; soft-vs-hard enforcement lands in slice 2 — slice 1 feeds these into
// the existing min/max machinery.
model DepartmentShiftTarget {
  id          String  @id @default(cuid())
  shiftTypeId String
  minCount    Int
  maxCount    Int?
  window      String
  windowDays  Int?
  windowCount Int     @default(1) // multiplier: "per N windows" (ignored for window="days")
  strength    String  @default("preference") // "preference" (soft) | "rule" (hard)
  perFte      Boolean @default(true)          // counts are per 1.0 FTE → scaled to each staff's FTE

  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([shiftTypeId, window, windowCount], map: "dept_shift_targets_shift_window_count_key")
  @@map("department_shift_targets")
}

model CountColumn {
  id         String   @id @default(cuid())
  label      String
  sortOrder  Int      @default(0)
  shiftCodes String[]

  @@map("count_columns")
}

// A rule deciding which staff get their own column on the PRINTED schedule.
// Rules combine as a union (OR): a staff column prints if it matches ANY enabled
// rule. Zero enabled rules => print everyone (backward compatible). Print-only —
// the on-screen grid always shows every staff so they remain schedulable.
model PrintColumnRule {
  id                String   @id @default(cuid())
  label             String
  sortOrder         Int      @default(0)
  enabled           Boolean  @default(true)
  mode              String   @default("include") // "include" (print matching) | "exclude" (print everyone EXCEPT matching)
  employmentTypeIds String[] @default([]) // empty = any employment type
  minFtePercentage  Float? // null = no lower bound
  maxFtePercentage  Float? // null = no upper bound
  shiftCodes        String[] @default([]) // legacy single shift selector — superseded by `conditions`; kept for back-compat synth
  shiftMatch        String   @default("any") // legacy "any" | "all" — superseded by `conditions`
  // Shift conditions (ANDed): each is { quantifier: has_any|has_none|has_all,
  // categories: (work|leave|off)[], codes: string[], except: string[] }. Expresses
  // e.g. "no work shift except ICU/CARD" or "any work or leave". See print-column-visibility.ts.
  conditions        Json     @default("[]")

  @@map("print_column_rules")
}

// A configurable AGGREGATE column on the printed schedule: instead of one column per
// staff, it lists (per day) the initials of the staff who match its rule and are
// scheduled that day. Replaces the old hardcoded "FB" collapse column. Reuses the same
// rule shape as PrintColumnRule (employmentTypeIds / FTE bounds / conditions). Three
// column-level extras:
//   - suppressMembers: when true, a member's individual column is hidden in print
//     (the aggregate "claims" them); when false, the member appears both individually
//     and in this column.
//   - isOther: marks a residual catch-all column — it has NO rule and lists staff who
//     appear in no other printed column (individual or aggregate). A per-row flag, not a
//     singleton: zero, one, or several isOther rows may exist (each lists the same
//     residual), all freely editable / movable / deletable.
//   - conditionScope: "month" (default) evaluates shift conditions over the whole printed
//     month; "day" evaluates per day, listing a member only on days whose shift matches.
//     Forced "month" for isOther (no rule). See print-aggregate-columns.ts.
// Print-only: the on-screen grid is unaffected. See print-aggregate-columns.ts.
model PrintAggregateColumn {
  id                String   @id @default(cuid())
  label             String
  sortOrder         Int      @default(0)
  enabled           Boolean  @default(true)
  suppressMembers   Boolean  @default(true) // hide members' individual columns in print
  isOther           Boolean  @default(false) // residual catch-all (no rule); per-row flag, not a singleton — 0/1/N allowed, each lists the same residual
  employmentTypeIds String[] @default([]) // empty = any employment type
  minFtePercentage  Float? // null = no lower bound
  maxFtePercentage  Float? // null = no upper bound
  // Shift conditions (ANDed): same shape as PrintColumnRule.conditions. Ignored for the
  // isOther column. See print-column-visibility.ts for the condition semantics.
  conditions        Json     @default("[]")
  // How the shift conditions are evaluated: "month" (default) = match over the whole
  // printed month, then list the member on every scheduled day; "day" = match per day,
  // listing the member only on days whose shift satisfies the conditions. Forced "month"
  // for the isOther catch-all (it has no conditions). See print-aggregate-columns.ts.
  conditionScope    String   @default("month")

  @@map("print_aggregate_columns")
}

// A saved snapshot of one calendar month's assignments. Versions are scoped per
// (year, month) — `month` is 0-based to match the grid's viewMonth (0=Jan..11=Dec).
// versionNumber auto-increments within each (year, month). At most one version per
// month is marked isCurrent (the last saved/restored point shown in the footer).
model ScheduleVersion {
  id            String   @id @default(cuid())
  year          Int
  month         Int // 0-based (0=Jan..11=Dec), matches the grid's viewMonth
  versionNumber Int // per-(year,month), increments
  comment       String?
  snapshot      Json // AssignmentSnapshot[] — the month's assignments
  snapshotHash  String // stable hash of snapshot content; lets the footer detect live drift
  isCurrent     Boolean  @default(false) // the active version for this (year, month)
  isAutoBackup  Boolean  @default(false) // auto-created to preserve state before a restore
  createdAt     DateTime @default(now())

  @@unique([year, month, versionNumber])
  @@index([year, month])
  @@map("schedule_versions")
}

// A date-specific scheduling request for one staff (e.g. "off 7/4", "no ORC
// or ORL next week", "AL 8/1–8/5"). Requests are the first dated, timestamped,
// per-staff constraint with their own approval lifecycle. They feed BOTH the
// manual scheduler (as cell warnings) and auto-schedule (as candidate gates),
// but only once status="approved" — pending requests render in the grid yet
// exert zero scheduling force. receivedAt is the "received-date stamp".
model ScheduleRequest {
  id           String    @id @default(cuid())
  staffId   String
  startDate    DateTime  @db.Date // inclusive; single-date request => startDate==endDate
  endDate      DateTime  @db.Date // inclusive
  kind         String // OFF | LEAVE | NEGATE_SHIFT | REQUEST_SHIFT
  shiftTypeIds String[]  @default([]) // NEGATE_SHIFT: shifts to exclude; REQUEST_SHIFT: shifts wanted
  leaveShiftTypeId String? // LEAVE: the leave shift type to pre-place (AL/SL/ILD…)
  offStrategyOrder String[] @default([]) // day-off requests: ordered fulfillment strategies the engine tries top-down (soft, lowest priority). Tokens: ORC_ADJACENT | ORL_PAIR | LEAVE:<shiftTypeId>. Empty = no preference.
  strength     String    @default("hard") // hard (forbid/force) | soft (avoid/prefer)
  status       String    @default("pending") // pending | approved | declined | fulfilled | withdrawn
  autoApproved Boolean   @default(false) // approval derived from a satisfying assignment (auto-revertible); false = sticky human decision
  source       String    @default("scheduler") // scheduler | staff | email
  receivedAt   DateTime  @default(now()) // when the request came in (the stamp)
  approvedAt   DateTime?
  approvedBy   String? // user id/initials of the approver
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  staff        Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  leaveShiftType  ShiftType? @relation("requestLeaveShift", fields: [leaveShiftTypeId], references: [id], onDelete: SetNull)

  @@index([staffId, startDate, endDate])
  @@index([status])
  @@map("schedule_requests")
}

// A dismissed ("muted") schedule alert. Mutes are SHARED across all logins
// (single-tenant) so silencing a known/intentional alert sticks for everyone.
// `alertKey` is a stable, VALUE-BEARING identity built by the alert pipeline
// (src/lib/alerts.ts) — it embeds the alert's numbers, so when the underlying
// value changes the key changes and the alert re-surfaces (you re-confirm it).
// Stale rows (keys no longer produced) are harmless; pruning is a later concern.
model MutedAlert {
  id       String   @id @default(cuid())
  alertKey String   @unique
  mutedBy  String? // login id/initials that muted it (informational; no FK)
  mutedAt  DateTime @default(now())

  @@map("muted_alerts")
}
