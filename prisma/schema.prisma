generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  manager
  viewer
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  passwordHash   String
  role           Role      @default(viewer)
  groupId        String?
  isActive       Boolean   @default(true)
  totpSecret     String?
  totpEnabled    Boolean   @default(false)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  group Group? @relation(fields: [groupId], references: [id])

  savedGraphViews SavedGraphView[]

  @@map("users")
}

model SavedGraphView {
  id        String   @id @default(cuid())
  name      String
  spec      Json // a GraphSpec
  ownerId   String? // User id of creator; null = department-owned (e.g. owner deleted)
  isShared  Boolean  @default(true) // default global; false = private to owner
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([isShared])
  @@map("saved_graph_views")
}

model Group {
  id                String   @id @default(cuid())
  name              String   @unique
  permissions       String[] @default([])
  level             Int      @default(0)
  isSystem          Boolean  @default(false)
  permissionsLocked Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  users             User[]

  @@map("groups")
}

model ShiftType {
  id              String   @id @default(cuid())
  name            String
  code            String   @unique
  defaultHours    Float
  countsTowardFte Boolean  @default(true)
  countsOnWeekend Boolean  @default(false)
  isLeave         Boolean  @default(false)
  isPaid          Boolean  @default(true)
  category        String   @default("work") // work, leave, imported, other
  color              String?
  sortOrder          Int      @default(0)
  isOffShift         Boolean  @default(false)
  isFillShift        Boolean  @default(false)
  schedulePriority   Int?
  weekendPaired      Boolean  @default(false)
  ignoresWorkingDays Boolean  @default(false)
  noConsecutiveGroup String?
  maxPerDay          Int?
  autoSchedulable    Boolean  @default(false)
  hotkey             String?
  dedicatedColumn    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments         Assignment[]
  desirabilityWeights DesirabilityWeight[]
  providerOverrides   ProviderShiftOverride[]
  eligibleRoles       ShiftTypeRole[]
  standingCommitments StandingCommitment[]
  eligibleProviders            ProviderEligibleShift[]
  defaultForEmploymentTypes    EmploymentTypeDefaultShift[]
  followRulesAsSource  ShiftFollowRule[] @relation("followRuleSource")
  followRulesAsAllowed ShiftFollowRule[] @relation("followRuleAllowed")
  shiftEligibilityRules        ShiftEligibilityRule[]
  shiftMinimumTargets          ShiftMinimumTarget[]
  requestLeaveShifts           ScheduleRequest[] @relation("requestLeaveShift")

  @@map("shift_types")
}

model ShiftTypeRole {
  id          String @id @default(cuid())
  shiftTypeId String
  role        String

  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([shiftTypeId, role])
  @@map("shift_type_roles")
}

model EmploymentType {
  id                     String   @id @default(cuid())
  name                   String   @unique
  defaultIsAutoScheduled Boolean  @default(true)
  defaultFtePercentage   Float    @default(1.0)
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  providers                Provider[]
  defaultEligibleShifts    EmploymentTypeDefaultShift[]
  defaultAvailability      EmploymentTypeDefaultAvailability[]

  @@map("employment_types")
}

model Provider {
  id                    String   @id @default(cuid())
  name                  String
  initials              String   @unique
  employmentTypeId      String
  ftePercentage         Float?   @default(1.0)
  fteSplit              Json?    // e.g. {"OR": 0.8, "ICU": 0.2}
  feeBasisHoursPerShift Float?
  role                  String?
  specialQualifications String[] @default([])
  isTemporary           Boolean  @default(false)
  tempStartDate         DateTime?
  tempEndDate           DateTime?
  isActive              Boolean  @default(true)
  isAutoScheduled       Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  employmentType    EmploymentType         @relation(fields: [employmentTypeId], references: [id])
  assignments       Assignment[]
  shiftOverrides    ProviderShiftOverride[]
  standingCommitments StandingCommitment[]
  dayPreferences    ProviderDayPreference[]
  eligibleShifts          ProviderEligibleShift[]
  availabilityRules       AvailabilityRule[]     @relation("providerRules")
  conditionedRules        AvailabilityRule[]     @relation("conditionProvider")
  shiftEligibilityRules   ShiftEligibilityRule[]
  shiftMinimumTargets     ShiftMinimumTarget[]
  scheduleRequests        ScheduleRequest[]

  @@map("providers")
}

model ProviderShiftOverride {
  id          String @id @default(cuid())
  providerId  String
  shiftTypeId String
  durationHrs Float

  provider  Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([providerId, shiftTypeId])
  @@map("provider_shift_overrides")
}

model ProviderDayPreference {
  id         String @id @default(cuid())
  providerId String
  dayOfWeek  Int    // 0=Sun..6=Sat
  preference String // e.g. "ORC" — preferred shift on this day

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, dayOfWeek])
  @@map("provider_day_preferences")
}

model StandingCommitment {
  id          String @id @default(cuid())
  providerId  String
  shiftTypeId String
  dayOfWeek   Int?      // 0-6, null = any applicable day
  frequency   String    @default("weekly") // weekly, biweekly, monthly
  notes       String?

  provider  Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@map("standing_commitments")
}

model DesirabilityWeight {
  id          String @id @default(cuid())
  shiftTypeId String
  dayOfWeek   Int    // 0=Sun..6=Sat
  weight      Int    // -5 (terrible) to +5 (great)
  reason      String?

  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([shiftTypeId, dayOfWeek])
  @@map("desirability_weights")
}

model StaffingMinimum {
  id           String @id @default(cuid())
  role         String
  dayType      String // weekday, weekend, holiday
  minimumCount Int

  @@unique([role, dayType])
  @@map("staffing_minimums")
}

model ShiftCountRule {
  id         String @id @default(cuid())
  shiftCode  String
  dayType    String // weekday, weekend, holiday
  exactCount Int

  @@unique([shiftCode, dayType])
  @@map("shift_count_rules")
}

model StaffingRequirement {
  id        String @id @default(cuid())
  shiftCode String
  dayKey    String // "0"=Sun, "1"=Mon, ..., "6"=Sat, "holiday"
  minCount  Int    @default(0)

  @@unique([shiftCode, dayKey])
  @@map("staffing_requirements")
}

model PayPeriod {
  id          String   @id @default(cuid())
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  targetHours Float

  @@map("pay_periods")
}

model FteTarget {
  id            String @id @default(cuid())
  ftePercentage Float  @unique
  targetHours   Float

  @@map("fte_targets")
}

model Holiday {
  id   String   @id @default(cuid())
  date DateTime @unique @db.Date
  name String

  @@map("holidays")
}

model SchedulingPreferences {
  id                    String  @id @default(cuid())
  prefer3DayWeekends    Boolean @default(true)
  prefer4DayWeekends    Boolean @default(true)
  preferSequentialOff   Boolean @default(true)
  sequentialOffWeight   Float   @default(2)
  threeDayWeekendWeight   Float   @default(5)
  fourDayWeekendWeight  Float   @default(8)
  equityThresholdLow    Float   @default(0.25)
  equityThresholdMed    Float   @default(0.75)
  equityThresholdHigh   Float   @default(1.5)
  deviceTrustDays       Int     @default(30)
  dateFormat            String  @default("MMMM D, YYYY")

  @@map("scheduling_preferences")
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("login_logs")
}

model EquityFactor {
  id         String  @id @default(cuid())
  factorType String  // "desirability", "holiday", "shift"
  shiftCode  String? // only for factorType="shift"
  weight     Float   @default(1.0)
  enabled    Boolean @default(true)
  sortOrder  Int     @default(0)

  @@unique([factorType, shiftCode])
  @@map("equity_factors")
}

model Assignment {
  id          String   @id @default(cuid())
  providerId  String
  date        DateTime @db.Date
  shiftTypeId String
  isLocked    Boolean  @default(false)
  source      String   @default("manual") // manual, auto, imported
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider  Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([providerId, date])
  @@map("assignments")
}

model ProviderEligibleShift {
  id          String @id @default(cuid())
  providerId  String
  shiftTypeId String

  provider  Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([providerId, shiftTypeId])
  @@map("provider_eligible_shifts")
}

model EmploymentTypeDefaultShift {
  id               String @id @default(cuid())
  employmentTypeId String
  shiftTypeId      String

  employmentType EmploymentType @relation(fields: [employmentTypeId], references: [id], onDelete: Cascade)
  shiftType      ShiftType      @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([employmentTypeId, shiftTypeId])
  @@map("employment_type_default_shifts")
}

model AvailabilityRule {
  id                  String  @id @default(cuid())
  providerId          String
  dayOfWeek           Int     // 0=Sun..6=Sat
  type                String  @default("available") // "available" or "unavailable"
  strength            String  @default("rule") // "rule" or "preference"
  pattern             String  @default("every") // "every", "pp_week_1", "pp_week_2", "every_n"
  cycleLength         Int?    // for "every_n": 2=every other, 3=every third, etc.
  cycleOffset         Int?    // for "every_n": 0-indexed position in the cycle
  conditionProviderId String?
  conditionType       String? // "working" or "not_working"

  provider          Provider  @relation("providerRules", fields: [providerId], references: [id], onDelete: Cascade)
  conditionProvider Provider? @relation("conditionProvider", fields: [conditionProviderId], references: [id], onDelete: SetNull)

  @@map("availability_rules")
}

model EmploymentTypeDefaultAvailability {
  id               String @id @default(cuid())
  employmentTypeId String
  dayOfWeek        Int
  type             String @default("available")
  strength         String @default("rule")
  pattern          String @default("every")

  employmentType EmploymentType @relation(fields: [employmentTypeId], references: [id], onDelete: Cascade)

  @@map("employment_type_default_availability")
}

model ShiftFollowRule {
  id             String   @id @default(cuid())
  sourceShiftId  String
  allowedShiftId String?
  allowOffShifts Boolean  @default(false)
  mode           String   @default("allow")
  createdAt      DateTime @default(now())

  sourceShift  ShiftType  @relation("followRuleSource", fields: [sourceShiftId], references: [id], onDelete: Cascade)
  allowedShift ShiftType? @relation("followRuleAllowed", fields: [allowedShiftId], references: [id], onDelete: Cascade)

  @@unique([sourceShiftId, allowedShiftId])
  @@map("shift_follow_rules")
}

model ShiftEligibilityRule {
  id          String @id @default(cuid())
  providerId  String
  shiftTypeId String
  dayOfWeek   Int
  type        String @default("eligible")
  strength    String @default("rule")
  pattern     String @default("every")
  cycleLength Int?
  cycleOffset Int?

  provider  Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@index([providerId, shiftTypeId])
  @@map("shift_eligibility_rules")
}

model ShiftMinimumTarget {
  id          String @id @default(cuid())
  providerId  String
  shiftTypeId String
  minCount    Int
  maxCount    Int?
  window      String
  windowDays  Int?

  provider  Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  shiftType ShiftType @relation(fields: [shiftTypeId], references: [id], onDelete: Cascade)

  @@unique([providerId, shiftTypeId, window])
  @@map("shift_minimum_targets")
}

model CountColumn {
  id         String   @id @default(cuid())
  label      String
  sortOrder  Int      @default(0)
  shiftCodes String[]

  @@map("count_columns")
}

// A saved snapshot of one calendar month's assignments. Versions are scoped per
// (year, month) — `month` is 0-based to match the grid's viewMonth (0=Jan..11=Dec).
// versionNumber auto-increments within each (year, month). At most one version per
// month is marked isCurrent (the last saved/restored point shown in the footer).
model ScheduleVersion {
  id            String   @id @default(cuid())
  year          Int
  month         Int // 0-based (0=Jan..11=Dec), matches the grid's viewMonth
  versionNumber Int // per-(year,month), increments
  comment       String?
  snapshot      Json // AssignmentSnapshot[] — the month's assignments
  snapshotHash  String // stable hash of snapshot content; lets the footer detect live drift
  isCurrent     Boolean  @default(false) // the active version for this (year, month)
  isAutoBackup  Boolean  @default(false) // auto-created to preserve state before a restore
  createdAt     DateTime @default(now())

  @@unique([year, month, versionNumber])
  @@index([year, month])
  @@map("schedule_versions")
}

// A date-specific scheduling request for one provider (e.g. "off 7/4", "no ORC
// or ORL next week", "AL 8/1–8/5"). Requests are the first dated, timestamped,
// per-provider constraint with their own approval lifecycle. They feed BOTH the
// manual scheduler (as cell warnings) and auto-schedule (as candidate gates),
// but only once status="approved" — pending requests render in the grid yet
// exert zero scheduling force. receivedAt is the "received-date stamp".
model ScheduleRequest {
  id           String    @id @default(cuid())
  providerId   String
  startDate    DateTime  @db.Date // inclusive; single-date request => startDate==endDate
  endDate      DateTime  @db.Date // inclusive
  kind         String // OFF | LEAVE | NEGATE_SHIFT | REQUEST_SHIFT
  shiftTypeIds String[]  @default([]) // NEGATE_SHIFT: shifts to exclude; REQUEST_SHIFT: shifts wanted
  leaveShiftTypeId String? // LEAVE: the leave shift type to pre-place (AL/SL/ILD…)
  strength     String    @default("hard") // hard (forbid/force) | soft (avoid/prefer)
  status       String    @default("pending") // pending | approved | declined | fulfilled | withdrawn
  source       String    @default("scheduler") // scheduler | provider | email
  receivedAt   DateTime  @default(now()) // when the request came in (the stamp)
  approvedAt   DateTime?
  approvedBy   String? // user id/initials of the approver
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  provider        Provider   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  leaveShiftType  ShiftType? @relation("requestLeaveShift", fields: [leaveShiftTypeId], references: [id], onDelete: SetNull)

  @@index([providerId, startDate, endDate])
  @@index([status])
  @@map("schedule_requests")
}
